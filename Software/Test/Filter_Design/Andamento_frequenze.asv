% Carica dati Semi-discrete Sweep Up (3 file -> 9 colonne)
for i = 3:3:9
    file_index = i/3;
    fid = fopen(SSUp_path(file_index),'r');
    data = table2array(readtable(SSUp_path(file_index), 'Delimiter', ','));   
    righe_data = size(data, 1);
