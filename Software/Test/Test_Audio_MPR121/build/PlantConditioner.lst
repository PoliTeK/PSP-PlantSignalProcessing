  20:../../libs/DaisySP/Source/Utility/dsp.h **** */
  21:../../libs/DaisySP/Source/Utility/dsp.h **** #define PI_F 3.1415927410125732421875f
  22:../../libs/DaisySP/Source/Utility/dsp.h **** #define TWOPI_F (2.0f * PI_F)
  23:../../libs/DaisySP/Source/Utility/dsp.h **** #define HALFPI_F (PI_F * 0.5f)
  24:../../libs/DaisySP/Source/Utility/dsp.h **** #define DSY_MIN(in, mn) (in < mn ? in : mn)
  25:../../libs/DaisySP/Source/Utility/dsp.h **** #define DSY_MAX(in, mx) (in > mx ? in : mx)
  26:../../libs/DaisySP/Source/Utility/dsp.h **** #define DSY_CLAMP(in, mn, mx) (DSY_MIN(DSY_MAX(in, mn), mx))
  27:../../libs/DaisySP/Source/Utility/dsp.h **** #define DSY_COUNTOF(_arr) (sizeof(_arr) / sizeof(_arr[0]))
  28:../../libs/DaisySP/Source/Utility/dsp.h **** 
  29:../../libs/DaisySP/Source/Utility/dsp.h **** namespace daisysp
  30:../../libs/DaisySP/Source/Utility/dsp.h **** {
  31:../../libs/DaisySP/Source/Utility/dsp.h **** //Avoids division for random floats. e.g. rand() * kRandFrac
  32:../../libs/DaisySP/Source/Utility/dsp.h **** static constexpr float kRandFrac = 1.f / (float)RAND_MAX;
  33:../../libs/DaisySP/Source/Utility/dsp.h **** 
  34:../../libs/DaisySP/Source/Utility/dsp.h **** //Convert from semitones to other units. e.g. 2 ^ (kOneTwelfth * x)
  35:../../libs/DaisySP/Source/Utility/dsp.h **** static constexpr float kOneTwelfth = 1.f / 12.f;
  36:../../libs/DaisySP/Source/Utility/dsp.h **** 
  37:../../libs/DaisySP/Source/Utility/dsp.h **** /** efficient floating point min/max
  38:../../libs/DaisySP/Source/Utility/dsp.h **** c/o stephen mccaul
  39:../../libs/DaisySP/Source/Utility/dsp.h **** */
  40:../../libs/DaisySP/Source/Utility/dsp.h **** inline float fmax(float a, float b)
  41:../../libs/DaisySP/Source/Utility/dsp.h **** {
  42:../../libs/DaisySP/Source/Utility/dsp.h ****     float r;
  43:../../libs/DaisySP/Source/Utility/dsp.h **** #ifdef __arm__
  44:../../libs/DaisySP/Source/Utility/dsp.h ****     asm("vmaxnm.f32 %[d], %[n], %[m]" : [d] "=t"(r) : [n] "t"(a), [m] "t"(b) :);
  45:../../libs/DaisySP/Source/Utility/dsp.h **** #else
  46:../../libs/DaisySP/Source/Utility/dsp.h ****     r = (a > b) ? a : b;
  47:../../libs/DaisySP/Source/Utility/dsp.h **** #endif // __arm__
  48:../../libs/DaisySP/Source/Utility/dsp.h ****     return r;
  49:../../libs/DaisySP/Source/Utility/dsp.h **** }
  50:../../libs/DaisySP/Source/Utility/dsp.h **** 
  51:../../libs/DaisySP/Source/Utility/dsp.h **** inline float fmin(float a, float b)
  52:../../libs/DaisySP/Source/Utility/dsp.h **** {
  53:../../libs/DaisySP/Source/Utility/dsp.h ****     float r;
  54:../../libs/DaisySP/Source/Utility/dsp.h **** #ifdef __arm__
  55:../../libs/DaisySP/Source/Utility/dsp.h ****     asm("vminnm.f32 %[d], %[n], %[m]" : [d] "=t"(r) : [n] "t"(a), [m] "t"(b) :);
  56:../../libs/DaisySP/Source/Utility/dsp.h **** #else
  57:../../libs/DaisySP/Source/Utility/dsp.h ****     r = (a < b) ? a : b;
  58:../../libs/DaisySP/Source/Utility/dsp.h **** #endif // __arm__
  59:../../libs/DaisySP/Source/Utility/dsp.h ****     return r;
  60:../../libs/DaisySP/Source/Utility/dsp.h **** }
