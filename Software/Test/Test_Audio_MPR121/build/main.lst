 200:../../libs/libDaisy/src/sys/../../../../libs/libDaisy/src/dev/oled_ssd130x.h ****     void SoftSpiTransmit(uint8_t val)
 201:../../libs/libDaisy/src/sys/../../../../libs/libDaisy/src/dev/oled_ssd130x.h ****     {
 202:../../libs/libDaisy/src/sys/../../../../libs/libDaisy/src/dev/oled_ssd130x.h ****         // bit flip
 203:../../libs/libDaisy/src/sys/../../../../libs/libDaisy/src/dev/oled_ssd130x.h ****         val = ((val & 0x01) << 7) | ((val & 0x02) << 5) | ((val & 0x04) << 3)
