 180:../../libs/libDaisy/src/dev/mpr121.h ****         \param      touch The touch threshold value from 0 to 255.
 181:../../libs/libDaisy/src/dev/mpr121.h ****         \param      release The release threshold from 0 to 255.
 182:../../libs/libDaisy/src/dev/mpr121.h ****     */
 183:../../libs/libDaisy/src/dev/mpr121.h ****     void SetThresholds(uint8_t touch, uint8_t release)
 184:../../libs/libDaisy/src/dev/mpr121.h ****     {
 185:../../libs/libDaisy/src/dev/mpr121.h ****         // set all thresholds (the same)
 186:../../libs/libDaisy/src/dev/mpr121.h ****         for(uint8_t i = 0; i < 12; i++)
 187:../../libs/libDaisy/src/dev/mpr121.h ****         {
 188:../../libs/libDaisy/src/dev/mpr121.h ****             WriteRegister(MPR121_TOUCHTH_0 + 2 * i, touch);
 189:../../libs/libDaisy/src/dev/mpr121.h ****             WriteRegister(MPR121_RELEASETH_0 + 2 * i, release);
 190:../../libs/libDaisy/src/dev/mpr121.h ****         }
 191:../../libs/libDaisy/src/dev/mpr121.h ****     }
 192:../../libs/libDaisy/src/dev/mpr121.h **** 
 193:../../libs/libDaisy/src/dev/mpr121.h **** 
 194:../../libs/libDaisy/src/dev/mpr121.h ****     /** Read the filtered data from channel t. The ADC raw data outputs
 195:../../libs/libDaisy/src/dev/mpr121.h ****         run through 3 levels of digital filtering to filter out the high
 196:../../libs/libDaisy/src/dev/mpr121.h ****         frequency and low frequency noise encountered. For detailed information on
 197:../../libs/libDaisy/src/dev/mpr121.h ****         this filtering see page 6 of the device datasheet.
 198:../../libs/libDaisy/src/dev/mpr121.h ****         \param      t the channel to read
 199:../../libs/libDaisy/src/dev/mpr121.h ****         \returns    the filtered reading as a 10 bit unsigned value
 200:../../libs/libDaisy/src/dev/mpr121.h ****     */
 201:../../libs/libDaisy/src/dev/mpr121.h ****     uint16_t FilteredData(uint8_t t)
 202:../../libs/libDaisy/src/dev/mpr121.h ****     {
 203:../../libs/libDaisy/src/dev/mpr121.h ****         if(t > 12)
 204:../../libs/libDaisy/src/dev/mpr121.h ****             return 0;
 205:../../libs/libDaisy/src/dev/mpr121.h ****         return ReadRegister16(MPR121_FILTDATA_0L + t * 2);
ARM GAS  C:\Users\skipi\AppData\Local\Temp\cczrFxSu.s 			page 23


 206:../../libs/libDaisy/src/dev/mpr121.h ****     }
 207:../../libs/libDaisy/src/dev/mpr121.h **** 
 208:../../libs/libDaisy/src/dev/mpr121.h ****     /** Read the baseline value for the channel. The 3rd level filtered
 209:../../libs/libDaisy/src/dev/mpr121.h ****         result is internally 10bit but only high 8 bits are readable
 210:../../libs/libDaisy/src/dev/mpr121.h ****         from registers 0x1E~0x2A as the baseline value output for each channel.
 211:../../libs/libDaisy/src/dev/mpr121.h ****         \param      t the channel to read.
 212:../../libs/libDaisy/src/dev/mpr121.h ****         \returns    the baseline data that was read
 213:../../libs/libDaisy/src/dev/mpr121.h ****     */
 214:../../libs/libDaisy/src/dev/mpr121.h ****     uint16_t BaselineData(uint8_t t)
 215:../../libs/libDaisy/src/dev/mpr121.h ****     {
 216:../../libs/libDaisy/src/dev/mpr121.h ****         if(t > 12)
 217:../../libs/libDaisy/src/dev/mpr121.h ****             return 0;
 218:../../libs/libDaisy/src/dev/mpr121.h ****         uint16_t bl = ReadRegister8(MPR121_BASELINE_0 + t);
 219:../../libs/libDaisy/src/dev/mpr121.h ****         return (bl << 2);
 220:../../libs/libDaisy/src/dev/mpr121.h ****     }
 221:../../libs/libDaisy/src/dev/mpr121.h **** 
 222:../../libs/libDaisy/src/dev/mpr121.h ****     /** Read the touch status of all 13 channels as bit values in a 12 bit integer.
 223:../../libs/libDaisy/src/dev/mpr121.h ****         \returns    a 12 bit integer with each bit corresponding to the touch status
 224:../../libs/libDaisy/src/dev/mpr121.h ****         of a sensor. For example, if bit 0 is set then channel 0 of the
 225:../../libs/libDaisy/src/dev/mpr121.h ****         device is currently deemed to be touched.
 226:../../libs/libDaisy/src/dev/mpr121.h ****     */
 227:../../libs/libDaisy/src/dev/mpr121.h ****     uint16_t Touched()
 228:../../libs/libDaisy/src/dev/mpr121.h ****     {
 229:../../libs/libDaisy/src/dev/mpr121.h ****         uint16_t t = ReadRegister16(MPR121_TOUCHSTATUS_L);
 230:../../libs/libDaisy/src/dev/mpr121.h ****         return t & 0x0FFF;
 231:../../libs/libDaisy/src/dev/mpr121.h ****     }
 232:../../libs/libDaisy/src/dev/mpr121.h **** 
 233:../../libs/libDaisy/src/dev/mpr121.h ****     /** Read the contents of an 8 bit device register.
