 214:../../libs/libDaisy/src/dev/mpr121.h ****     uint16_t BaselineData(uint8_t t)
 215:../../libs/libDaisy/src/dev/mpr121.h ****     {
 216:../../libs/libDaisy/src/dev/mpr121.h ****         if(t > 12)
 217:../../libs/libDaisy/src/dev/mpr121.h ****             return 0;
 218:../../libs/libDaisy/src/dev/mpr121.h ****         uint16_t bl = ReadRegister8(MPR121_BASELINE_0 + t);
 219:../../libs/libDaisy/src/dev/mpr121.h ****         return (bl << 2);
 220:../../libs/libDaisy/src/dev/mpr121.h ****     }
 221:../../libs/libDaisy/src/dev/mpr121.h **** 
 222:../../libs/libDaisy/src/dev/mpr121.h ****     /** Read the touch status of all 13 channels as bit values in a 12 bit integer.
 223:../../libs/libDaisy/src/dev/mpr121.h ****         \returns    a 12 bit integer with each bit corresponding to the touch status
 224:../../libs/libDaisy/src/dev/mpr121.h ****         of a sensor. For example, if bit 0 is set then channel 0 of the
 225:../../libs/libDaisy/src/dev/mpr121.h ****         device is currently deemed to be touched.
 226:../../libs/libDaisy/src/dev/mpr121.h ****     */
