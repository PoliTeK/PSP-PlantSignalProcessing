 188:../../libs/libDaisy/src/hid/disp/display.h **** /** This class is intended as a intermediary class for your actual implementation of the OneBitGrap
 189:../../libs/libDaisy/src/hid/disp/display.h ****  *  interface. It uses the CRTP design pattern where the template argument is the child class. It p
 190:../../libs/libDaisy/src/hid/disp/display.h ****  *  implementations for most of the functions, except DrawPixel(), Update() and Fill(), which you'l
 191:../../libs/libDaisy/src/hid/disp/display.h ****  *  to provide in your child class.
 192:../../libs/libDaisy/src/hid/disp/display.h ****  *  The main goal of this class is to provide common drawing functions without relying on massive a
 193:../../libs/libDaisy/src/hid/disp/display.h ****  *  virtual function calls that would result in a performance loss. To achieve this, any drawing fu
 194:../../libs/libDaisy/src/hid/disp/display.h ****  *  is implemented here and internally calls other drawing functions (e.g. DrawRect() which interna
 195:../../libs/libDaisy/src/hid/disp/display.h ****  *  DrawPixel() and DrawLine()) makes these calls via the qualified name of these functions to expl
 196:../../libs/libDaisy/src/hid/disp/display.h ****  *  suppress the virtual dispatch mechanism like this:
ARM GAS  C:\Users\matte\AppData\Local\Temp\ccvehO0v.s 			page 15


 197:../../libs/libDaisy/src/hid/disp/display.h ****  * 
 198:../../libs/libDaisy/src/hid/disp/display.h ****  *      ChildType::DrawPixel(...); // no virtual function call; direct call into the child class fu
 199:../../libs/libDaisy/src/hid/disp/display.h ****  *  
 200:../../libs/libDaisy/src/hid/disp/display.h ****  *  To create a custom OneBitGraphicsDisplay implementation, you can 
 201:../../libs/libDaisy/src/hid/disp/display.h ****  *  A) inherit from OneBitGraphicsDisplay directly and provide all the drawing functions yourself
 202:../../libs/libDaisy/src/hid/disp/display.h ****  *  B) Inherit from OneBitGraphicsDisplayImpl and only provide DrawPixel(), Fill() and Update()
 203:../../libs/libDaisy/src/hid/disp/display.h ****  *     like this:
 204:../../libs/libDaisy/src/hid/disp/display.h ****  *  
 205:../../libs/libDaisy/src/hid/disp/display.h ****  *      class MyDisplayClass : public OneBitGraphicsDisplayImpl<MyDisplayClass> 
 206:../../libs/libDaisy/src/hid/disp/display.h ****  *      {
 207:../../libs/libDaisy/src/hid/disp/display.h ****  *      public:
 208:../../libs/libDaisy/src/hid/disp/display.h ****  *          void Fill() override { ... };
 209:../../libs/libDaisy/src/hid/disp/display.h ****  *          void DrawPixel(uint_fast8_t x, uint_fast8_t y, bool on) override { ... };
 210:../../libs/libDaisy/src/hid/disp/display.h ****  *          void Update() override { ... }
 211:../../libs/libDaisy/src/hid/disp/display.h ****  *      };
 212:../../libs/libDaisy/src/hid/disp/display.h ****  *  
 213:../../libs/libDaisy/src/hid/disp/display.h ****  */
