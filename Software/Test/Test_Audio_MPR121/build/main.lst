  48:../../libs/libDaisy/src/per/sai.h ****     {
  49:../../libs/libDaisy/src/per/sai.h ****         /** Specifies the internal peripheral to use (mapped to different hardware pins) */
  50:../../libs/libDaisy/src/per/sai.h ****         enum class Peripheral
  51:../../libs/libDaisy/src/per/sai.h ****         {
  52:../../libs/libDaisy/src/per/sai.h ****             SAI_1,
  53:../../libs/libDaisy/src/per/sai.h ****             SAI_2,
  54:../../libs/libDaisy/src/per/sai.h ****         };
  55:../../libs/libDaisy/src/per/sai.h **** 
  56:../../libs/libDaisy/src/per/sai.h ****         /** Rate at which samples will be streaming to/from the device. */
