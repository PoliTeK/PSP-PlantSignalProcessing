  36:../../libs/libDaisy/src/per/dac.h ****         BOTH,
  37:../../libs/libDaisy/src/per/dac.h ****     };
  38:../../libs/libDaisy/src/per/dac.h **** 
  39:../../libs/libDaisy/src/per/dac.h ****     /** Sets the Mode for the DAC channels.
  40:../../libs/libDaisy/src/per/dac.h ****      **
  41:../../libs/libDaisy/src/per/dac.h ****      ** Polling mode uses the blocking mode to transmit a single value at a time.
  42:../../libs/libDaisy/src/per/dac.h ****      **
  43:../../libs/libDaisy/src/per/dac.h ****      ** DMA mode uses a buffer, and periodically transmits it triggering a 
  44:../../libs/libDaisy/src/per/dac.h ****      ** callback to fill the buffer when it is ready for more samples.
  45:../../libs/libDaisy/src/per/dac.h ****      ***/
