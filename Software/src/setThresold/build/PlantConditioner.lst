 205:../../libs/libDaisy/src/dev/mpr121.h ****     /** Read the filtered data from channel t. The ADC raw data outputs
 206:../../libs/libDaisy/src/dev/mpr121.h ****         run through 3 levels of digital filtering to filter out the high
 207:../../libs/libDaisy/src/dev/mpr121.h ****         frequency and low frequency noise encountered. For detailed information on
 208:../../libs/libDaisy/src/dev/mpr121.h ****         this filtering see page 6 of the device datasheet.
 209:../../libs/libDaisy/src/dev/mpr121.h ****         \param      t the channel to read
 210:../../libs/libDaisy/src/dev/mpr121.h ****         \returns    the filtered reading as a 10 bit unsigned value
 211:../../libs/libDaisy/src/dev/mpr121.h ****     */
 212:../../libs/libDaisy/src/dev/mpr121.h ****     uint16_t FilteredData(uint8_t t)
 213:../../libs/libDaisy/src/dev/mpr121.h ****     {
 214:../../libs/libDaisy/src/dev/mpr121.h ****         if(t > 12)
 215:../../libs/libDaisy/src/dev/mpr121.h ****             return 0;
 216:../../libs/libDaisy/src/dev/mpr121.h ****         return ReadRegister16(MPR121_FILTDATA_0L + t * 2);
 217:../../libs/libDaisy/src/dev/mpr121.h ****     }
 218:../../libs/libDaisy/src/dev/mpr121.h **** 
 219:../../libs/libDaisy/src/dev/mpr121.h ****     /** Read the baseline value for the channel. The 3rd level filtered
 220:../../libs/libDaisy/src/dev/mpr121.h ****         result is internally 10bit but only high 8 bits are readable
 221:../../libs/libDaisy/src/dev/mpr121.h ****         from registers 0x1E~0x2A as the baseline value output for each channel.
 222:../../libs/libDaisy/src/dev/mpr121.h ****         \param      t the channel to read.
 223:../../libs/libDaisy/src/dev/mpr121.h ****         \returns    the baseline data that was read
 224:../../libs/libDaisy/src/dev/mpr121.h ****     */
 225:../../libs/libDaisy/src/dev/mpr121.h ****     uint16_t BaselineData(uint8_t t)
 226:../../libs/libDaisy/src/dev/mpr121.h ****     {
 227:../../libs/libDaisy/src/dev/mpr121.h ****         if(t > 12)
 228:../../libs/libDaisy/src/dev/mpr121.h ****             return 0;
 229:../../libs/libDaisy/src/dev/mpr121.h ****         uint16_t bl = ReadRegister8(MPR121_BASELINE_0 + t);
 230:../../libs/libDaisy/src/dev/mpr121.h ****         return (bl << 2);
 231:../../libs/libDaisy/src/dev/mpr121.h ****     }
 232:../../libs/libDaisy/src/dev/mpr121.h **** 
 233:../../libs/libDaisy/src/dev/mpr121.h ****     /** Read the touch status of all 13 channels as bit values in a 12 bit integer.
 234:../../libs/libDaisy/src/dev/mpr121.h ****         \returns    a 12 bit integer with each bit corresponding to the touch status
 235:../../libs/libDaisy/src/dev/mpr121.h ****         of a sensor. For example, if bit 0 is set then channel 0 of the
 236:../../libs/libDaisy/src/dev/mpr121.h ****         device is currently deemed to be touched.
 237:../../libs/libDaisy/src/dev/mpr121.h ****     */
 238:../../libs/libDaisy/src/dev/mpr121.h ****     uint16_t Touched()
 239:../../libs/libDaisy/src/dev/mpr121.h ****     {
 240:../../libs/libDaisy/src/dev/mpr121.h ****         uint16_t t = ReadRegister16(MPR121_TOUCHSTATUS_L);
 241:../../libs/libDaisy/src/dev/mpr121.h ****         return t & 0x0FFF;
 242:../../libs/libDaisy/src/dev/mpr121.h ****     }
