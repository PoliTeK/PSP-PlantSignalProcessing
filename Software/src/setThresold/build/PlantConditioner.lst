  73:../../libs/libDaisy/src/daisy_core.h **** 
  74:../../libs/libDaisy/src/daisy_core.h **** /** 
  75:../../libs/libDaisy/src/daisy_core.h ****     Converts unsigned 8-bit to float
  76:../../libs/libDaisy/src/daisy_core.h ****     \param x Number to be scaled.
