  64:../../libs/libDaisy/src/daisy_core.h **** /** 
  65:../../libs/libDaisy/src/daisy_core.h ****     Computes cube.
  66:../../libs/libDaisy/src/daisy_core.h ****     \param x Number to be cubed
  67:../../libs/libDaisy/src/daisy_core.h ****     \return x ^ 3
  68:../../libs/libDaisy/src/daisy_core.h **** */
  69:../../libs/libDaisy/src/daisy_core.h **** FORCE_INLINE float cube(float x)
  70:../../libs/libDaisy/src/daisy_core.h **** {
