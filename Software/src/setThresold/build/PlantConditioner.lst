 173:../../libs/libDaisy/src/dev/mpr121.h ****     /** Set the touch and release thresholds for all 13 channels on the
 174:../../libs/libDaisy/src/dev/mpr121.h ****         device to the passed values.
 175:../../libs/libDaisy/src/dev/mpr121.h ****         \param      touch The touch threshold value from 0 to 255.
 176:../../libs/libDaisy/src/dev/mpr121.h ****         \param      release The release threshold from 0 to 255.
 177:../../libs/libDaisy/src/dev/mpr121.h ****     */
 178:../../libs/libDaisy/src/dev/mpr121.h ****     void SetThresholds(uint8_t touch, uint8_t release)
 179:../../libs/libDaisy/src/dev/mpr121.h ****     {
 180:../../libs/libDaisy/src/dev/mpr121.h ****         // set all thresholds (the same)
 181:../../libs/libDaisy/src/dev/mpr121.h ****         for(uint8_t i = 0; i < 12; i++)
 182:../../libs/libDaisy/src/dev/mpr121.h ****         {
 183:../../libs/libDaisy/src/dev/mpr121.h ****             WriteRegister(MPR121_TOUCHTH_0 + 2 * i, touch);
 184:../../libs/libDaisy/src/dev/mpr121.h ****             WriteRegister(MPR121_RELEASETH_0 + 2 * i, release);
 185:../../libs/libDaisy/src/dev/mpr121.h ****         }
 186:../../libs/libDaisy/src/dev/mpr121.h ****     }
 187:../../libs/libDaisy/src/dev/mpr121.h **** 
 188:../../libs/libDaisy/src/dev/mpr121.h ****     /** Set the touch and release threshold for a specific channel on the
 189:../../libs/libDaisy/src/dev/mpr121.h ****         device to the passed values.
 190:../../libs/libDaisy/src/dev/mpr121.h ****         \param      touch The touch threshold value from 0 to 255.
 191:../../libs/libDaisy/src/dev/mpr121.h ****         \param      release The release threshold from 0 to 255.
 192:../../libs/libDaisy/src/dev/mpr121.h ****         \param      channel The channel from 0 to 11
 193:../../libs/libDaisy/src/dev/mpr121.h ****     */
 194:../../libs/libDaisy/src/dev/mpr121.h ****     void SetThreshold(uint8_t touch, uint8_t release, uint8_t channel)
 195:../../libs/libDaisy/src/dev/mpr121.h ****     {
 196:../../libs/libDaisy/src/dev/mpr121.h ****         if (channel < 12)
 197:../../libs/libDaisy/src/dev/mpr121.h ****         {
 198:../../libs/libDaisy/src/dev/mpr121.h ****             WriteRegister(MPR121_TOUCHTH_0 + 2 * channel, touch);
 199:../../libs/libDaisy/src/dev/mpr121.h ****             WriteRegister(MPR121_RELEASETH_0 + 2 * channel, release);
 200:../../libs/libDaisy/src/dev/mpr121.h ****         }
 201:../../libs/libDaisy/src/dev/mpr121.h ****     }
