 189:../../libs/PolitekDSP/libs/libDaisy/../../libs/libDaisy/src/dev/mpr121.h ****     /** Read the filtered data from channel t. The ADC raw data outputs
 190:../../libs/PolitekDSP/libs/libDaisy/../../libs/libDaisy/src/dev/mpr121.h ****         run through 3 levels of digital filtering to filter out the high
 191:../../libs/PolitekDSP/libs/libDaisy/../../libs/libDaisy/src/dev/mpr121.h ****         frequency and low frequency noise encountered. For detailed information on
 192:../../libs/PolitekDSP/libs/libDaisy/../../libs/libDaisy/src/dev/mpr121.h ****         this filtering see page 6 of the device datasheet.
 193:../../libs/PolitekDSP/libs/libDaisy/../../libs/libDaisy/src/dev/mpr121.h ****         \param      t the channel to read
 194:../../libs/PolitekDSP/libs/libDaisy/../../libs/libDaisy/src/dev/mpr121.h ****         \returns    the filtered reading as a 10 bit unsigned value
 195:../../libs/PolitekDSP/libs/libDaisy/../../libs/libDaisy/src/dev/mpr121.h ****     */
 196:../../libs/PolitekDSP/libs/libDaisy/../../libs/libDaisy/src/dev/mpr121.h ****     uint16_t FilteredData(uint8_t t)
 197:../../libs/PolitekDSP/libs/libDaisy/../../libs/libDaisy/src/dev/mpr121.h ****     {
 198:../../libs/PolitekDSP/libs/libDaisy/../../libs/libDaisy/src/dev/mpr121.h ****         if(t > 12)
 199:../../libs/PolitekDSP/libs/libDaisy/../../libs/libDaisy/src/dev/mpr121.h ****             return 0;
 200:../../libs/PolitekDSP/libs/libDaisy/../../libs/libDaisy/src/dev/mpr121.h ****         return ReadRegister16(MPR121_FILTDATA_0L + t * 2);
 201:../../libs/PolitekDSP/libs/libDaisy/../../libs/libDaisy/src/dev/mpr121.h ****     }
 202:../../libs/PolitekDSP/libs/libDaisy/../../libs/libDaisy/src/dev/mpr121.h **** 
 203:../../libs/PolitekDSP/libs/libDaisy/../../libs/libDaisy/src/dev/mpr121.h ****     /** Read the baseline value for the channel. The 3rd level filtered
 204:../../libs/PolitekDSP/libs/libDaisy/../../libs/libDaisy/src/dev/mpr121.h ****         result is internally 10bit but only high 8 bits are readable
 205:../../libs/PolitekDSP/libs/libDaisy/../../libs/libDaisy/src/dev/mpr121.h ****         from registers 0x1E~0x2A as the baseline value output for each channel.
 206:../../libs/PolitekDSP/libs/libDaisy/../../libs/libDaisy/src/dev/mpr121.h ****         \param      t the channel to read.
 207:../../libs/PolitekDSP/libs/libDaisy/../../libs/libDaisy/src/dev/mpr121.h ****         \returns    the baseline data that was read
 208:../../libs/PolitekDSP/libs/libDaisy/../../libs/libDaisy/src/dev/mpr121.h ****     */
 209:../../libs/PolitekDSP/libs/libDaisy/../../libs/libDaisy/src/dev/mpr121.h ****     uint16_t BaselineData(uint8_t t)
 210:../../libs/PolitekDSP/libs/libDaisy/../../libs/libDaisy/src/dev/mpr121.h ****     {
 211:../../libs/PolitekDSP/libs/libDaisy/../../libs/libDaisy/src/dev/mpr121.h ****         if(t > 12)
 212:../../libs/PolitekDSP/libs/libDaisy/../../libs/libDaisy/src/dev/mpr121.h ****             return 0;
 213:../../libs/PolitekDSP/libs/libDaisy/../../libs/libDaisy/src/dev/mpr121.h ****         uint16_t bl = ReadRegister8(MPR121_BASELINE_0 + t);
 214:../../libs/PolitekDSP/libs/libDaisy/../../libs/libDaisy/src/dev/mpr121.h ****         return (bl << 2);
 215:../../libs/PolitekDSP/libs/libDaisy/../../libs/libDaisy/src/dev/mpr121.h ****     }
 216:../../libs/PolitekDSP/libs/libDaisy/../../libs/libDaisy/src/dev/mpr121.h **** 
 217:../../libs/PolitekDSP/libs/libDaisy/../../libs/libDaisy/src/dev/mpr121.h ****     /** Read the touch status of all 13 channels as bit values in a 12 bit integer.
 218:../../libs/PolitekDSP/libs/libDaisy/../../libs/libDaisy/src/dev/mpr121.h ****         \returns    a 12 bit integer with each bit corresponding to the touch status
 219:../../libs/PolitekDSP/libs/libDaisy/../../libs/libDaisy/src/dev/mpr121.h ****         of a sensor. For example, if bit 0 is set then channel 0 of the
 220:../../libs/PolitekDSP/libs/libDaisy/../../libs/libDaisy/src/dev/mpr121.h ****         device is currently deemed to be touched.
 221:../../libs/PolitekDSP/libs/libDaisy/../../libs/libDaisy/src/dev/mpr121.h ****     */
 222:../../libs/PolitekDSP/libs/libDaisy/../../libs/libDaisy/src/dev/mpr121.h ****     uint16_t Touched()
 223:../../libs/PolitekDSP/libs/libDaisy/../../libs/libDaisy/src/dev/mpr121.h ****     {
 224:../../libs/PolitekDSP/libs/libDaisy/../../libs/libDaisy/src/dev/mpr121.h ****         uint16_t t = ReadRegister16(MPR121_TOUCHSTATUS_L);
 225:../../libs/PolitekDSP/libs/libDaisy/../../libs/libDaisy/src/dev/mpr121.h ****         return t & 0x0FFF;
 226:../../libs/PolitekDSP/libs/libDaisy/../../libs/libDaisy/src/dev/mpr121.h ****     }
