 256:../libs/libDaisy/src/dev/mpr121.h ****     */
 257:../libs/libDaisy/src/dev/mpr121.h ****     void WriteRegister(uint8_t reg, uint8_t value)
 258:../libs/libDaisy/src/dev/mpr121.h ****     {
 259:../libs/libDaisy/src/dev/mpr121.h ****         // MPR121 must be put in Stop Mode to write to most registers
 260:../libs/libDaisy/src/dev/mpr121.h ****         bool stop_required = true;
 261:../libs/libDaisy/src/dev/mpr121.h **** 
 262:../libs/libDaisy/src/dev/mpr121.h ****         // first get the current set value of the MPR121_ECR register
 263:../libs/libDaisy/src/dev/mpr121.h ****         uint8_t ecr_reg = MPR121_ECR;
