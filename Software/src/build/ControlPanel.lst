 271:../libs/libDaisy/src/dev/mpr121.h ****         {
 272:../libs/libDaisy/src/dev/mpr121.h ****             stop_required = false;
 273:../libs/libDaisy/src/dev/mpr121.h ****         }
 274:../libs/libDaisy/src/dev/mpr121.h **** 
 275:../libs/libDaisy/src/dev/mpr121.h ****         if(stop_required)
 276:../libs/libDaisy/src/dev/mpr121.h ****         {
 277:../libs/libDaisy/src/dev/mpr121.h ****             // clear this register to set stop mode
 278:../libs/libDaisy/src/dev/mpr121.h ****             SetTransportErr(transport_.Write(buff, 2));
 279:../libs/libDaisy/src/dev/mpr121.h ****         }
 280:../libs/libDaisy/src/dev/mpr121.h **** 
 281:../libs/libDaisy/src/dev/mpr121.h ****         buff[0] = reg;
 282:../libs/libDaisy/src/dev/mpr121.h ****         buff[1] = value;
 283:../libs/libDaisy/src/dev/mpr121.h ****         SetTransportErr(transport_.Write(buff, 2));
 284:../libs/libDaisy/src/dev/mpr121.h **** 
 285:../libs/libDaisy/src/dev/mpr121.h ****         if(stop_required)
 286:../libs/libDaisy/src/dev/mpr121.h ****         {
 287:../libs/libDaisy/src/dev/mpr121.h ****             // write back the previous set ECR settings
 288:../libs/libDaisy/src/dev/mpr121.h ****             buff[0] = ecr_reg;
 289:../libs/libDaisy/src/dev/mpr121.h ****             buff[1] = ecr_backup;
 290:../libs/libDaisy/src/dev/mpr121.h ****             SetTransportErr(transport_.Write(buff, 2));
