  29:../libs/PoliTeKDSP/libs/DaisySP/Source/Utility/dsp.h **** namespace daisysp
  30:../libs/PoliTeKDSP/libs/DaisySP/Source/Utility/dsp.h **** {
  31:../libs/PoliTeKDSP/libs/DaisySP/Source/Utility/dsp.h **** //Avoids division for random floats. e.g. rand() * kRandFrac
  32:../libs/PoliTeKDSP/libs/DaisySP/Source/Utility/dsp.h **** static constexpr float kRandFrac = 1.f / (float)RAND_MAX;
  33:../libs/PoliTeKDSP/libs/DaisySP/Source/Utility/dsp.h **** 
  34:../libs/PoliTeKDSP/libs/DaisySP/Source/Utility/dsp.h **** //Convert from semitones to other units. e.g. 2 ^ (kOneTwelfth * x)
  35:../libs/PoliTeKDSP/libs/DaisySP/Source/Utility/dsp.h **** static constexpr float kOneTwelfth = 1.f / 12.f;
  36:../libs/PoliTeKDSP/libs/DaisySP/Source/Utility/dsp.h **** 
  37:../libs/PoliTeKDSP/libs/DaisySP/Source/Utility/dsp.h **** /** efficient floating point min/max
