 189:../libs/PoliTeKDSP/libs/libDaisy/src/dev/mpr121.h ****     /** Read the filtered data from channel t. The ADC raw data outputs
 190:../libs/PoliTeKDSP/libs/libDaisy/src/dev/mpr121.h ****         run through 3 levels of digital filtering to filter out the high
 191:../libs/PoliTeKDSP/libs/libDaisy/src/dev/mpr121.h ****         frequency and low frequency noise encountered. For detailed information on
 192:../libs/PoliTeKDSP/libs/libDaisy/src/dev/mpr121.h ****         this filtering see page 6 of the device datasheet.
 193:../libs/PoliTeKDSP/libs/libDaisy/src/dev/mpr121.h ****         \param      t the channel to read
 194:../libs/PoliTeKDSP/libs/libDaisy/src/dev/mpr121.h ****         \returns    the filtered reading as a 10 bit unsigned value
 195:../libs/PoliTeKDSP/libs/libDaisy/src/dev/mpr121.h ****     */
 196:../libs/PoliTeKDSP/libs/libDaisy/src/dev/mpr121.h ****     uint16_t FilteredData(uint8_t t)
 197:../libs/PoliTeKDSP/libs/libDaisy/src/dev/mpr121.h ****     {
 198:../libs/PoliTeKDSP/libs/libDaisy/src/dev/mpr121.h ****         if(t > 12)
 199:../libs/PoliTeKDSP/libs/libDaisy/src/dev/mpr121.h ****             return 0;
 200:../libs/PoliTeKDSP/libs/libDaisy/src/dev/mpr121.h ****         return ReadRegister16(MPR121_FILTDATA_0L + t * 2);
 201:../libs/PoliTeKDSP/libs/libDaisy/src/dev/mpr121.h ****     }
 202:../libs/PoliTeKDSP/libs/libDaisy/src/dev/mpr121.h **** 
 203:../libs/PoliTeKDSP/libs/libDaisy/src/dev/mpr121.h ****     /** Read the baseline value for the channel. The 3rd level filtered
 204:../libs/PoliTeKDSP/libs/libDaisy/src/dev/mpr121.h ****         result is internally 10bit but only high 8 bits are readable
ARM GAS  C:\Users\skipi\AppData\Local\Temp\ccUZkxb5.s 			page 22


 205:../libs/PoliTeKDSP/libs/libDaisy/src/dev/mpr121.h ****         from registers 0x1E~0x2A as the baseline value output for each channel.
 206:../libs/PoliTeKDSP/libs/libDaisy/src/dev/mpr121.h ****         \param      t the channel to read.
 207:../libs/PoliTeKDSP/libs/libDaisy/src/dev/mpr121.h ****         \returns    the baseline data that was read
 208:../libs/PoliTeKDSP/libs/libDaisy/src/dev/mpr121.h ****     */
 209:../libs/PoliTeKDSP/libs/libDaisy/src/dev/mpr121.h ****     uint16_t BaselineData(uint8_t t)
 210:../libs/PoliTeKDSP/libs/libDaisy/src/dev/mpr121.h ****     {
 211:../libs/PoliTeKDSP/libs/libDaisy/src/dev/mpr121.h ****         if(t > 12)
 212:../libs/PoliTeKDSP/libs/libDaisy/src/dev/mpr121.h ****             return 0;
 213:../libs/PoliTeKDSP/libs/libDaisy/src/dev/mpr121.h ****         uint16_t bl = ReadRegister8(MPR121_BASELINE_0 + t);
