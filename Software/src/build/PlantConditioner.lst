  44:../libs/PoliTeKDSP/libs/DaisySP/Source/Utility/dsp.h ****     asm("vmaxnm.f32 %[d], %[n], %[m]" : [d] "=t"(r) : [n] "t"(a), [m] "t"(b) :);
  45:../libs/PoliTeKDSP/libs/DaisySP/Source/Utility/dsp.h **** #else
  46:../libs/PoliTeKDSP/libs/DaisySP/Source/Utility/dsp.h ****     r = (a > b) ? a : b;
