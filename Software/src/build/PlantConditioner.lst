 198:../libs/libDaisy/src/dev/mpr121.h ****             return 0;
 199:../libs/libDaisy/src/dev/mpr121.h ****         return ReadRegister16(MPR121_FILTDATA_0L + t * 2);
 200:../libs/libDaisy/src/dev/mpr121.h ****     }
 201:../libs/libDaisy/src/dev/mpr121.h **** 
 202:../libs/libDaisy/src/dev/mpr121.h ****     /** Read the baseline value for the channel. The 3rd level filtered
 203:../libs/libDaisy/src/dev/mpr121.h ****         result is internally 10bit but only high 8 bits are readable
 204:../libs/libDaisy/src/dev/mpr121.h ****         from registers 0x1E~0x2A as the baseline value output for each channel.
 205:../libs/libDaisy/src/dev/mpr121.h ****         \param      t the channel to read.
 206:../libs/libDaisy/src/dev/mpr121.h ****         \returns    the baseline data that was read
 207:../libs/libDaisy/src/dev/mpr121.h ****     */
 208:../libs/libDaisy/src/dev/mpr121.h ****     uint16_t BaselineData(uint8_t t)
 209:../libs/libDaisy/src/dev/mpr121.h ****     {
