 205:../libs/PoliTeKDSP/libs/libDaisy/src/dev/mpr121.h ****         from registers 0x1E~0x2A as the baseline value output for each channel.
 206:../libs/PoliTeKDSP/libs/libDaisy/src/dev/mpr121.h ****         \param      t the channel to read.
 207:../libs/PoliTeKDSP/libs/libDaisy/src/dev/mpr121.h ****         \returns    the baseline data that was read
 208:../libs/PoliTeKDSP/libs/libDaisy/src/dev/mpr121.h ****     */
 209:../libs/PoliTeKDSP/libs/libDaisy/src/dev/mpr121.h ****     uint16_t BaselineData(uint8_t t)
 210:../libs/PoliTeKDSP/libs/libDaisy/src/dev/mpr121.h ****     {
 211:../libs/PoliTeKDSP/libs/libDaisy/src/dev/mpr121.h ****         if(t > 12)
