 215:../libs/PoliTeKDSP/libs/libDaisy/src/dev/mpr121.h ****     }
 216:../libs/PoliTeKDSP/libs/libDaisy/src/dev/mpr121.h **** 
 217:../libs/PoliTeKDSP/libs/libDaisy/src/dev/mpr121.h ****     /** Read the touch status of all 13 channels as bit values in a 12 bit integer.
 218:../libs/PoliTeKDSP/libs/libDaisy/src/dev/mpr121.h ****         \returns    a 12 bit integer with each bit corresponding to the touch status
 219:../libs/PoliTeKDSP/libs/libDaisy/src/dev/mpr121.h ****         of a sensor. For example, if bit 0 is set then channel 0 of the
