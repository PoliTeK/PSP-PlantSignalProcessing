  24:../libs/PoliTeKDSP/libs/DaisySP/Source/Filters/ladder.h **** //-----------------------------------------------------------
  25:../libs/PoliTeKDSP/libs/DaisySP/Source/Filters/ladder.h **** // Huovilainen New Moog (HNM) model as per CMJ jun 2006
  26:../libs/PoliTeKDSP/libs/DaisySP/Source/Filters/ladder.h **** // Richard van Hoesel, v. 1.03, Feb. 14 2021
  27:../libs/PoliTeKDSP/libs/DaisySP/Source/Filters/ladder.h **** // v1.7 (Infrasonic/Daisy) add configurable filter mode
  28:../libs/PoliTeKDSP/libs/DaisySP/Source/Filters/ladder.h **** // v1.6 (Infrasonic/Daisy) removes polyphase FIR, uses 4x linear
  29:../libs/PoliTeKDSP/libs/DaisySP/Source/Filters/ladder.h **** //      oversampling for performance reasons
  30:../libs/PoliTeKDSP/libs/DaisySP/Source/Filters/ladder.h **** // v1.5 adds polyphase FIR or Linear interpolation
  31:../libs/PoliTeKDSP/libs/DaisySP/Source/Filters/ladder.h **** // v1.4 FC extended to 18.7kHz, max res to 1.8, 4x oversampling,
  32:../libs/PoliTeKDSP/libs/DaisySP/Source/Filters/ladder.h **** //      and a minor Q-tuning adjustment
  33:../libs/PoliTeKDSP/libs/DaisySP/Source/Filters/ladder.h **** // v.1.03 adds oversampling, extended resonance,
  34:../libs/PoliTeKDSP/libs/DaisySP/Source/Filters/ladder.h **** // and exposes parameters input_drive and passband_gain
  35:../libs/PoliTeKDSP/libs/DaisySP/Source/Filters/ladder.h **** // v.1.02 now includes both cutoff and resonance "CV" modulation inputs
  36:../libs/PoliTeKDSP/libs/DaisySP/Source/Filters/ladder.h **** // please retain this header if you use this code.
  37:../libs/PoliTeKDSP/libs/DaisySP/Source/Filters/ladder.h **** //-----------------------------------------------------------
