  18:../libs/PoliTeKDSP/libs/DaisySP/Source/Control/adsr.h **** /** Distinct stages that the phase of the envelope can be located in.
  19:../libs/PoliTeKDSP/libs/DaisySP/Source/Control/adsr.h **** - IDLE   = located at phase location 0, and not currently running
  20:../libs/PoliTeKDSP/libs/DaisySP/Source/Control/adsr.h **** - ATTACK  = First segment of envelope where phase moves from 0 to 1
  21:../libs/PoliTeKDSP/libs/DaisySP/Source/Control/adsr.h **** - DECAY   = Second segment of envelope where phase moves from 1 to SUSTAIN value
  22:../libs/PoliTeKDSP/libs/DaisySP/Source/Control/adsr.h **** - RELEASE =     Fourth segment of envelop where phase moves from SUSTAIN to 0
  23:../libs/PoliTeKDSP/libs/DaisySP/Source/Control/adsr.h **** */
  24:../libs/PoliTeKDSP/libs/DaisySP/Source/Control/adsr.h **** enum
  25:../libs/PoliTeKDSP/libs/DaisySP/Source/Control/adsr.h **** {
  26:../libs/PoliTeKDSP/libs/DaisySP/Source/Control/adsr.h ****     ADSR_SEG_IDLE    = 0,
  27:../libs/PoliTeKDSP/libs/DaisySP/Source/Control/adsr.h ****     ADSR_SEG_ATTACK  = 1,
  28:../libs/PoliTeKDSP/libs/DaisySP/Source/Control/adsr.h ****     ADSR_SEG_DECAY   = 2,
  29:../libs/PoliTeKDSP/libs/DaisySP/Source/Control/adsr.h ****     ADSR_SEG_RELEASE = 4
  30:../libs/PoliTeKDSP/libs/DaisySP/Source/Control/adsr.h **** };
