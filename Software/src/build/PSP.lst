  16:../libs/libDaisy/../../libs/libDaisy/src/per/adc.h **** 
  17:../libs/libDaisy/../../libs/libDaisy/src/per/adc.h **** /* While there may not be many configuration options here,
  18:../libs/libDaisy/../../libs/libDaisy/src/per/adc.h **** using a struct like this allows us to add more configuration
  19:../libs/libDaisy/../../libs/libDaisy/src/per/adc.h **** later without breaking existing functionality.
  20:../libs/libDaisy/../../libs/libDaisy/src/per/adc.h **** */
  21:../libs/libDaisy/../../libs/libDaisy/src/per/adc.h **** 
  22:../libs/libDaisy/../../libs/libDaisy/src/per/adc.h **** /** @brief   Configuration Structure for an ADC Channel 
  23:../libs/libDaisy/../../libs/libDaisy/src/per/adc.h ****  *  @details This can be used to configure a a single input, 
  24:../libs/libDaisy/../../libs/libDaisy/src/per/adc.h ****  *           or a multiplexed input, allowing up to 8 inputs on 
  25:../libs/libDaisy/../../libs/libDaisy/src/per/adc.h ****  *           one channel.
  26:../libs/libDaisy/../../libs/libDaisy/src/per/adc.h ****  *  @note    Sharing data lines to multiple muxes _is_ possible, but
  27:../libs/libDaisy/../../libs/libDaisy/src/per/adc.h ****  *           each channel sharing data lines must be set to the maximum
  28:../libs/libDaisy/../../libs/libDaisy/src/per/adc.h ****  *           number of channels, even if some multiplexers have fewer
  29:../libs/libDaisy/../../libs/libDaisy/src/per/adc.h ****  *           inputs connected.
  30:../libs/libDaisy/../../libs/libDaisy/src/per/adc.h **** */
  31:../libs/libDaisy/../../libs/libDaisy/src/per/adc.h **** struct AdcChannelConfig
  32:../libs/libDaisy/../../libs/libDaisy/src/per/adc.h **** {
