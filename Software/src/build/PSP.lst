   9:../libs/libDaisy/../../libs/libDaisy/src/per/adc.h **** #define DSY_ADC_MAX_CHANNELS 16 /**< Maximum number of ADC channels */
  10:../libs/libDaisy/../../libs/libDaisy/src/per/adc.h **** 
