  52:../libs/PoliTeKDSP/libs/libDaisy/src/per/tim.h ****             TIM_4,     /**< 16-bit counter */
  53:../libs/PoliTeKDSP/libs/libDaisy/src/per/tim.h ****             TIM_5,     /**< 32-bit counter*/
  54:../libs/PoliTeKDSP/libs/libDaisy/src/per/tim.h ****         };
  55:../libs/PoliTeKDSP/libs/libDaisy/src/per/tim.h **** 
  56:../libs/PoliTeKDSP/libs/libDaisy/src/per/tim.h ****         /** @brief Direction of the auto-reload counter. 
  57:../libs/PoliTeKDSP/libs/libDaisy/src/per/tim.h ****          ** @todo Add support for the various  
