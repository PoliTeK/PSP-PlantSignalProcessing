 220:../libs/PoliTeKDSP/libs/libDaisy/src/hid/disp/display.h **** 
 221:../libs/PoliTeKDSP/libs/libDaisy/src/hid/disp/display.h ****     void DrawLine(uint_fast8_t x1,
 222:../libs/PoliTeKDSP/libs/libDaisy/src/hid/disp/display.h ****                   uint_fast8_t y1,
 223:../libs/PoliTeKDSP/libs/libDaisy/src/hid/disp/display.h ****                   uint_fast8_t x2,
 224:../libs/PoliTeKDSP/libs/libDaisy/src/hid/disp/display.h ****                   uint_fast8_t y2,
 225:../libs/PoliTeKDSP/libs/libDaisy/src/hid/disp/display.h ****                   bool         on) override
 226:../libs/PoliTeKDSP/libs/libDaisy/src/hid/disp/display.h ****     {
 227:../libs/PoliTeKDSP/libs/libDaisy/src/hid/disp/display.h ****         int_fast16_t deltaX = abs((int_fast16_t)x2 - (int_fast16_t)x1);
 228:../libs/PoliTeKDSP/libs/libDaisy/src/hid/disp/display.h ****         int_fast16_t deltaY = abs((int_fast16_t)y2 - (int_fast16_t)y1);
