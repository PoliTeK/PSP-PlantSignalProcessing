  50:../libs/PoliTeKDSP/libs/libDaisy/src/per/tim.h ****             TIM_2 = 0, /**< 32-bit counter */
  51:../libs/PoliTeKDSP/libs/libDaisy/src/per/tim.h ****             TIM_3,     /**< 16-bit counter */
  52:../libs/PoliTeKDSP/libs/libDaisy/src/per/tim.h ****             TIM_4,     /**< 16-bit counter */
  53:../libs/PoliTeKDSP/libs/libDaisy/src/per/tim.h ****             TIM_5,     /**< 32-bit counter*/
  54:../libs/PoliTeKDSP/libs/libDaisy/src/per/tim.h ****         };
  55:../libs/PoliTeKDSP/libs/libDaisy/src/per/tim.h **** 
  56:../libs/PoliTeKDSP/libs/libDaisy/src/per/tim.h ****         /** @brief Direction of the auto-reload counter. 
  57:../libs/PoliTeKDSP/libs/libDaisy/src/per/tim.h ****          ** @todo Add support for the various  
  58:../libs/PoliTeKDSP/libs/libDaisy/src/per/tim.h ****          ** versions of Up/Down counters.
  59:../libs/PoliTeKDSP/libs/libDaisy/src/per/tim.h ****          ** */
  60:../libs/PoliTeKDSP/libs/libDaisy/src/per/tim.h ****         enum class CounterDir
  61:../libs/PoliTeKDSP/libs/libDaisy/src/per/tim.h ****         {
  62:../libs/PoliTeKDSP/libs/libDaisy/src/per/tim.h ****             UP = 0,
  63:../libs/PoliTeKDSP/libs/libDaisy/src/per/tim.h ****             DOWN,
  64:../libs/PoliTeKDSP/libs/libDaisy/src/per/tim.h ****         };
  65:../libs/PoliTeKDSP/libs/libDaisy/src/per/tim.h **** 
  66:../libs/PoliTeKDSP/libs/libDaisy/src/per/tim.h ****         Peripheral periph; /**< Hardware Peripheral */
  67:../libs/PoliTeKDSP/libs/libDaisy/src/per/tim.h ****         CounterDir dir;    /**< Counter direction */
  68:../libs/PoliTeKDSP/libs/libDaisy/src/per/tim.h **** 
  69:../libs/PoliTeKDSP/libs/libDaisy/src/per/tim.h ****         /** @brief period in ticks at TIM frequency that counter will reset based on dir
  70:../libs/PoliTeKDSP/libs/libDaisy/src/per/tim.h ****          *  @note TIM3 and TIM4 are both 16-bit timers. So the period maximum is 0xffff.
  71:../libs/PoliTeKDSP/libs/libDaisy/src/per/tim.h ****         */
  72:../libs/PoliTeKDSP/libs/libDaisy/src/per/tim.h ****         uint32_t period;
  73:../libs/PoliTeKDSP/libs/libDaisy/src/per/tim.h ****         bool     enable_irq; /**< Enable interrupt for user based callback */
  74:../libs/PoliTeKDSP/libs/libDaisy/src/per/tim.h **** 
  75:../libs/PoliTeKDSP/libs/libDaisy/src/per/tim.h ****         /* @brief Constructor for default states */
  76:../libs/PoliTeKDSP/libs/libDaisy/src/per/tim.h ****         Config()
  77:../libs/PoliTeKDSP/libs/libDaisy/src/per/tim.h ****         : periph(Peripheral::TIM_2),
  78:../libs/PoliTeKDSP/libs/libDaisy/src/per/tim.h ****           dir(CounterDir::UP),
  79:../libs/PoliTeKDSP/libs/libDaisy/src/per/tim.h ****           period(0xffffffff),
  80:../libs/PoliTeKDSP/libs/libDaisy/src/per/tim.h ****           enable_irq(false)
  81:../libs/PoliTeKDSP/libs/libDaisy/src/per/tim.h ****         {
  82:../libs/PoliTeKDSP/libs/libDaisy/src/per/tim.h ****         }
  83:../libs/PoliTeKDSP/libs/libDaisy/src/per/tim.h ****     };
  84:../libs/PoliTeKDSP/libs/libDaisy/src/per/tim.h **** 
