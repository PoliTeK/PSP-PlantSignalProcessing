  10:../libs/PoliTeKDSP/libs/libDaisy/src/per/sai.h **** /** 
  11:../libs/PoliTeKDSP/libs/libDaisy/src/per/sai.h ****  * Support for I2S Audio Protocol with different bit-depth, samplerate options
  12:../libs/PoliTeKDSP/libs/libDaisy/src/per/sai.h ****  * Allows for master or slave, as well as freedom of selecting direction, 
  13:../libs/PoliTeKDSP/libs/libDaisy/src/per/sai.h ****  * and other behavior for each peripheral, and block.
  14:../libs/PoliTeKDSP/libs/libDaisy/src/per/sai.h ****  * 
  15:../libs/PoliTeKDSP/libs/libDaisy/src/per/sai.h ****  * DMA Transfer commands must use buffers located within non-cached memory or use cache maintenance
  16:../libs/PoliTeKDSP/libs/libDaisy/src/per/sai.h ****  * To declare an unitialized global element in the DMA memory section:
  17:../libs/PoliTeKDSP/libs/libDaisy/src/per/sai.h ****  *    int32_t DSY_DMA_BUFFER_SECTOR my_buffer[96];
  18:../libs/PoliTeKDSP/libs/libDaisy/src/per/sai.h ****  *
  19:../libs/PoliTeKDSP/libs/libDaisy/src/per/sai.h ****  * Callback functions will be called once per half of the buffer. In the above example, 
  20:../libs/PoliTeKDSP/libs/libDaisy/src/per/sai.h ****  * the callback function would be called once for every 48 samples.
  21:../libs/PoliTeKDSP/libs/libDaisy/src/per/sai.h ****  * 
  22:../libs/PoliTeKDSP/libs/libDaisy/src/per/sai.h ****  * Use SAI Handle like this:
  23:../libs/PoliTeKDSP/libs/libDaisy/src/per/sai.h ****  * 
  24:../libs/PoliTeKDSP/libs/libDaisy/src/per/sai.h ****  *  SaiHandle::Config sai_config;
  25:../libs/PoliTeKDSP/libs/libDaisy/src/per/sai.h ****  *  sai_config.periph          = SaiHandle::Config::Peripheral::SAI_1;
  26:../libs/PoliTeKDSP/libs/libDaisy/src/per/sai.h ****  *  sai_config.sr              = SaiHandle::Config::SampleRate::SAI_48KHZ;
  27:../libs/PoliTeKDSP/libs/libDaisy/src/per/sai.h ****  *  sai_config.bit_depth       = SaiHandle::Config::BitDepth::SAI_24BIT;
  28:../libs/PoliTeKDSP/libs/libDaisy/src/per/sai.h ****  *  sai_config.a_sync          = SaiHandle::Config::Sync::MASTER;
ARM GAS  C:\Users\skipi\AppData\Local\Temp\cc2SdWwi.s 			page 211


