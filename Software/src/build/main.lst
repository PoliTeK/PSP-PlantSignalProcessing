 241:../libs/PoliTeKDSP/libs/libDaisy/src/hid/disp/display.h ****         // class. The only way around this is to use this very verbose syntax:
 242:../libs/PoliTeKDSP/libs/libDaisy/src/hid/disp/display.h ****         ((ChildType*)(this))->ChildType::DrawPixel(x2, y2, on);
