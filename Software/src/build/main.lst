  41:../libs/PoliTeKDSP/libs/libDaisy/src/per/tim.h ****     /** @brief Configuration struct for the Peripheral
  42:../libs/PoliTeKDSP/libs/libDaisy/src/per/tim.h ****      *  @note These settings are used during initialization
  43:../libs/PoliTeKDSP/libs/libDaisy/src/per/tim.h ****      *   and changing them afterwards may not have the desired effect.
  44:../libs/PoliTeKDSP/libs/libDaisy/src/per/tim.h ****      */
  45:../libs/PoliTeKDSP/libs/libDaisy/src/per/tim.h ****     struct Config
  46:../libs/PoliTeKDSP/libs/libDaisy/src/per/tim.h ****     {
  47:../libs/PoliTeKDSP/libs/libDaisy/src/per/tim.h ****         /** @brief Hardware Timer to configure, and use. */
