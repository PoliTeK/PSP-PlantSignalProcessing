  78:../libs/PoliTeKDSP/libs/libDaisy/src/per/tim.h ****           dir(CounterDir::UP),
  79:../libs/PoliTeKDSP/libs/libDaisy/src/per/tim.h ****           period(0xffffffff),
  80:../libs/PoliTeKDSP/libs/libDaisy/src/per/tim.h ****           enable_irq(false)
  81:../libs/PoliTeKDSP/libs/libDaisy/src/per/tim.h ****         {
  82:../libs/PoliTeKDSP/libs/libDaisy/src/per/tim.h ****         }
  83:../libs/PoliTeKDSP/libs/libDaisy/src/per/tim.h ****     };
