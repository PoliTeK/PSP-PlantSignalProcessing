  29:../libs/PoliTeKDSP/libs/libDaisy/src/per/dac.h ****     };
  30:../libs/PoliTeKDSP/libs/libDaisy/src/per/dac.h **** 
  31:../libs/PoliTeKDSP/libs/libDaisy/src/per/dac.h ****     /** Selects which channel(s) will be configured for use. */
  32:../libs/PoliTeKDSP/libs/libDaisy/src/per/dac.h ****     enum class Channel
  33:../libs/PoliTeKDSP/libs/libDaisy/src/per/dac.h ****     {
  34:../libs/PoliTeKDSP/libs/libDaisy/src/per/dac.h ****         ONE,
  35:../libs/PoliTeKDSP/libs/libDaisy/src/per/dac.h ****         TWO,
  36:../libs/PoliTeKDSP/libs/libDaisy/src/per/dac.h ****         BOTH,
  37:../libs/PoliTeKDSP/libs/libDaisy/src/per/dac.h ****     };
  38:../libs/PoliTeKDSP/libs/libDaisy/src/per/dac.h **** 
  39:../libs/PoliTeKDSP/libs/libDaisy/src/per/dac.h ****     /** Sets the Mode for the DAC channels.
  40:../libs/PoliTeKDSP/libs/libDaisy/src/per/dac.h ****      **
  41:../libs/PoliTeKDSP/libs/libDaisy/src/per/dac.h ****      ** Polling mode uses the blocking mode to transmit a single value at a time.
  42:../libs/PoliTeKDSP/libs/libDaisy/src/per/dac.h ****      **
  43:../libs/PoliTeKDSP/libs/libDaisy/src/per/dac.h ****      ** DMA mode uses a buffer, and periodically transmits it triggering a 
  44:../libs/PoliTeKDSP/libs/libDaisy/src/per/dac.h ****      ** callback to fill the buffer when it is ready for more samples.
  45:../libs/PoliTeKDSP/libs/libDaisy/src/per/dac.h ****      ***/
  46:../libs/PoliTeKDSP/libs/libDaisy/src/per/dac.h ****     enum class Mode
