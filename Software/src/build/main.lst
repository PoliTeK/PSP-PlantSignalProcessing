 234:../libs/PoliTeKDSP/libs/libDaisy/src/hid/disp/display.h ****         // If we write "ChildType::DrawPixel(x2, y2, on);", we end up with
 235:../libs/PoliTeKDSP/libs/libDaisy/src/hid/disp/display.h ****         // all sorts of weird compiler errors when the Child class is a template
 236:../libs/PoliTeKDSP/libs/libDaisy/src/hid/disp/display.h ****         // class. The only way around this is to use this very verbose syntax:
 237:../libs/PoliTeKDSP/libs/libDaisy/src/hid/disp/display.h ****         ((ChildType*)(this))->ChildType::DrawPixel(x2, y2, on);
