 294:../libs/PoliTeKDSP/libs/libDaisy/src/hid/disp/display.h ****     {
 295:../libs/PoliTeKDSP/libs/libDaisy/src/hid/disp/display.h ****         // Values to calculate the circle
 296:../libs/PoliTeKDSP/libs/libDaisy/src/hid/disp/display.h ****         int_fast16_t t_x, t_y, err, e2;
 297:../libs/PoliTeKDSP/libs/libDaisy/src/hid/disp/display.h **** 
 298:../libs/PoliTeKDSP/libs/libDaisy/src/hid/disp/display.h ****         // Temporary values to speed up comparisons
 299:../libs/PoliTeKDSP/libs/libDaisy/src/hid/disp/display.h ****         float t_sxy, t_syx, t_sxny, t_synx;
