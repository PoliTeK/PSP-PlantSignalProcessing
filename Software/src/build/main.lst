 306:../libs/PoliTeKDSP/libs/libDaisy/src/hid/disp/display.h **** 
 307:../libs/PoliTeKDSP/libs/libDaisy/src/hid/disp/display.h ****         d1 = d2 = d3 = d4 = true;
 308:../libs/PoliTeKDSP/libs/libDaisy/src/hid/disp/display.h **** 
 309:../libs/PoliTeKDSP/libs/libDaisy/src/hid/disp/display.h ****         bool circle = false;
 310:../libs/PoliTeKDSP/libs/libDaisy/src/hid/disp/display.h **** 
 311:../libs/PoliTeKDSP/libs/libDaisy/src/hid/disp/display.h ****         if(sweep < 0)
 312:../libs/PoliTeKDSP/libs/libDaisy/src/hid/disp/display.h ****         {
 313:../libs/PoliTeKDSP/libs/libDaisy/src/hid/disp/display.h ****             start_angle += sweep;
 314:../libs/PoliTeKDSP/libs/libDaisy/src/hid/disp/display.h ****             sweep = -sweep;
 315:../libs/PoliTeKDSP/libs/libDaisy/src/hid/disp/display.h ****         }
 316:../libs/PoliTeKDSP/libs/libDaisy/src/hid/disp/display.h **** 
 317:../libs/PoliTeKDSP/libs/libDaisy/src/hid/disp/display.h ****         start_angle_rad = deg2rad(start_angle);
 318:../libs/PoliTeKDSP/libs/libDaisy/src/hid/disp/display.h ****         end_angle_rad   = deg2rad(start_angle + sweep);
 319:../libs/PoliTeKDSP/libs/libDaisy/src/hid/disp/display.h **** 
 320:../libs/PoliTeKDSP/libs/libDaisy/src/hid/disp/display.h ****         start_x = cos(start_angle_rad) * radius;
 321:../libs/PoliTeKDSP/libs/libDaisy/src/hid/disp/display.h ****         start_y = -sin(start_angle_rad) * radius;
 322:../libs/PoliTeKDSP/libs/libDaisy/src/hid/disp/display.h ****         end_x   = cos(end_angle_rad) * radius;
