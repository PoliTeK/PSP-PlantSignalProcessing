 186:../../libs/PoliTeKDSP/libs/libDaisy/src/dev/oled_ssd130x.h ****     void SendCommand(uint8_t cmd)
 187:../../libs/PoliTeKDSP/libs/libDaisy/src/dev/oled_ssd130x.h ****     {
 188:../../libs/PoliTeKDSP/libs/libDaisy/src/dev/oled_ssd130x.h ****         pin_dc_.Write(0);
 189:../../libs/PoliTeKDSP/libs/libDaisy/src/dev/oled_ssd130x.h ****         SoftSpiTransmit(cmd);
