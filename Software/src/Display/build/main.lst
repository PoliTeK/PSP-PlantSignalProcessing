   6:../../libs/PoliTeKDSP/libs/libDaisy/src/per/dac.h **** 
   7:../../libs/PoliTeKDSP/libs/libDaisy/src/per/dac.h **** namespace daisy
   8:../../libs/PoliTeKDSP/libs/libDaisy/src/per/dac.h **** {
   9:../../libs/PoliTeKDSP/libs/libDaisy/src/per/dac.h **** /** @brief DAC handle for Built-in DAC Peripheral 
  10:../../libs/PoliTeKDSP/libs/libDaisy/src/per/dac.h ****  *  @ingroup per_analog
  11:../../libs/PoliTeKDSP/libs/libDaisy/src/per/dac.h ****  ** 
  12:../../libs/PoliTeKDSP/libs/libDaisy/src/per/dac.h ****  ** For now only Normal Mode is supported,
  13:../../libs/PoliTeKDSP/libs/libDaisy/src/per/dac.h ****  ** Sample and hold mode provides reduced power consumption, but requires a bit more setup.
  14:../../libs/PoliTeKDSP/libs/libDaisy/src/per/dac.h ****  **
  15:../../libs/PoliTeKDSP/libs/libDaisy/src/per/dac.h ****  ** For now connecting the DAC through other internal peripherals is also not supported.
  16:../../libs/PoliTeKDSP/libs/libDaisy/src/per/dac.h ****  **
  17:../../libs/PoliTeKDSP/libs/libDaisy/src/per/dac.h ****  ** Since the DAC channels have dedicated pins we don't need to pass in a pin config like with
  18:../../libs/PoliTeKDSP/libs/libDaisy/src/per/dac.h ****  ** other modules. However, it is still important to not try to use the DAC pins for anything else.
  19:../../libs/PoliTeKDSP/libs/libDaisy/src/per/dac.h ****  ** DAC Channel 1 is on PA4, and DAC Channel 2 is on PA5
  20:../../libs/PoliTeKDSP/libs/libDaisy/src/per/dac.h ****  ***/
  21:../../libs/PoliTeKDSP/libs/libDaisy/src/per/dac.h **** class DacHandle
  22:../../libs/PoliTeKDSP/libs/libDaisy/src/per/dac.h **** {
  23:../../libs/PoliTeKDSP/libs/libDaisy/src/per/dac.h ****   public:
  24:../../libs/PoliTeKDSP/libs/libDaisy/src/per/dac.h ****     /** Return Values for the DacHandle class */
  25:../../libs/PoliTeKDSP/libs/libDaisy/src/per/dac.h ****     enum class Result
  26:../../libs/PoliTeKDSP/libs/libDaisy/src/per/dac.h ****     {
  27:../../libs/PoliTeKDSP/libs/libDaisy/src/per/dac.h ****         OK,
  28:../../libs/PoliTeKDSP/libs/libDaisy/src/per/dac.h ****         ERR,
  29:../../libs/PoliTeKDSP/libs/libDaisy/src/per/dac.h ****     };
  30:../../libs/PoliTeKDSP/libs/libDaisy/src/per/dac.h **** 
  31:../../libs/PoliTeKDSP/libs/libDaisy/src/per/dac.h ****     /** Selects which channel(s) will be configured for use. */
  32:../../libs/PoliTeKDSP/libs/libDaisy/src/per/dac.h ****     enum class Channel
  33:../../libs/PoliTeKDSP/libs/libDaisy/src/per/dac.h ****     {
  34:../../libs/PoliTeKDSP/libs/libDaisy/src/per/dac.h ****         ONE,
  35:../../libs/PoliTeKDSP/libs/libDaisy/src/per/dac.h ****         TWO,
  36:../../libs/PoliTeKDSP/libs/libDaisy/src/per/dac.h ****         BOTH,
  37:../../libs/PoliTeKDSP/libs/libDaisy/src/per/dac.h ****     };
  38:../../libs/PoliTeKDSP/libs/libDaisy/src/per/dac.h **** 
  39:../../libs/PoliTeKDSP/libs/libDaisy/src/per/dac.h ****     /** Sets the Mode for the DAC channels.
  40:../../libs/PoliTeKDSP/libs/libDaisy/src/per/dac.h ****      **
  41:../../libs/PoliTeKDSP/libs/libDaisy/src/per/dac.h ****      ** Polling mode uses the blocking mode to transmit a single value at a time.
  42:../../libs/PoliTeKDSP/libs/libDaisy/src/per/dac.h ****      **
ARM GAS  C:\Users\skipi\AppData\Local\Temp\ccs8qXFk.s 			page 196


  43:../../libs/PoliTeKDSP/libs/libDaisy/src/per/dac.h ****      ** DMA mode uses a buffer, and periodically transmits it triggering a 
  44:../../libs/PoliTeKDSP/libs/libDaisy/src/per/dac.h ****      ** callback to fill the buffer when it is ready for more samples.
  45:../../libs/PoliTeKDSP/libs/libDaisy/src/per/dac.h ****      ***/
  46:../../libs/PoliTeKDSP/libs/libDaisy/src/per/dac.h ****     enum class Mode
  47:../../libs/PoliTeKDSP/libs/libDaisy/src/per/dac.h ****     {
  48:../../libs/PoliTeKDSP/libs/libDaisy/src/per/dac.h ****         POLLING,
  49:../../libs/PoliTeKDSP/libs/libDaisy/src/per/dac.h ****         DMA,
  50:../../libs/PoliTeKDSP/libs/libDaisy/src/per/dac.h ****     };
  51:../../libs/PoliTeKDSP/libs/libDaisy/src/per/dac.h **** 
  52:../../libs/PoliTeKDSP/libs/libDaisy/src/per/dac.h ****     /** Sets the number of bits per sample transmitted out of the DAC.
  53:../../libs/PoliTeKDSP/libs/libDaisy/src/per/dac.h ****      ** The output range will be: 0V - VDDA
  54:../../libs/PoliTeKDSP/libs/libDaisy/src/per/dac.h ****      ** The resolution will be roughly: bitdepth / (VDDA - 0V) 
  55:../../libs/PoliTeKDSP/libs/libDaisy/src/per/dac.h ****      ***/
  56:../../libs/PoliTeKDSP/libs/libDaisy/src/per/dac.h ****     enum class BitDepth
  57:../../libs/PoliTeKDSP/libs/libDaisy/src/per/dac.h ****     {
  58:../../libs/PoliTeKDSP/libs/libDaisy/src/per/dac.h ****         BITS_8,
