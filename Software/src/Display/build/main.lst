 259:../../libs/PoliTeKDSP/libs/libDaisy/src/dev/oled_ssd130x.h ****         typename Transport::Config transport_config;
 260:../../libs/PoliTeKDSP/libs/libDaisy/src/dev/oled_ssd130x.h ****     };
 261:../../libs/PoliTeKDSP/libs/libDaisy/src/dev/oled_ssd130x.h **** 
 262:../../libs/PoliTeKDSP/libs/libDaisy/src/dev/oled_ssd130x.h ****     void Init(Config config)
 263:../../libs/PoliTeKDSP/libs/libDaisy/src/dev/oled_ssd130x.h ****     {
