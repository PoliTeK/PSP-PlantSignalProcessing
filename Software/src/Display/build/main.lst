 207:../../libs/libDaisy/src/sys/../../../../libs/libDaisy/src/dev/oled_ssd130x.h ****         for(uint8_t bit = 0u; bit < 8u; bit++)
 208:../../libs/libDaisy/src/sys/../../../../libs/libDaisy/src/dev/oled_ssd130x.h ****         {
 209:../../libs/libDaisy/src/sys/../../../../libs/libDaisy/src/dev/oled_ssd130x.h ****             pin_mosi_.Write((val & (1 << bit)) ? 1 : 0);
