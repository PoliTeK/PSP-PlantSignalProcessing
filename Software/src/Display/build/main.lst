 273:../../libs/PoliTeKDSP/libs/libDaisy/src/dev/oled_ssd130x.h ****             case 16:
 274:../../libs/PoliTeKDSP/libs/libDaisy/src/dev/oled_ssd130x.h ****                 // Display Clock Divide Ratio
 275:../../libs/PoliTeKDSP/libs/libDaisy/src/dev/oled_ssd130x.h ****                 transport_.SendCommand(0xD5);
 276:../../libs/PoliTeKDSP/libs/libDaisy/src/dev/oled_ssd130x.h ****                 transport_.SendCommand(0x60);
 277:../../libs/PoliTeKDSP/libs/libDaisy/src/dev/oled_ssd130x.h ****                 // Multiplex Ratio
 278:../../libs/PoliTeKDSP/libs/libDaisy/src/dev/oled_ssd130x.h ****                 transport_.SendCommand(0xA8);
