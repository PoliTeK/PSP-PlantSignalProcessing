 223:../../libs/PoliTeKDSP/libs/libDaisy/src/dev/oled_ssd130x.h ****         // bit flip
 224:../../libs/PoliTeKDSP/libs/libDaisy/src/dev/oled_ssd130x.h ****         val = ((val & 0x01) << 7) | ((val & 0x02) << 5) | ((val & 0x04) << 3)
